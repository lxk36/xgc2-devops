{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://xgc2.dev/schemas/product.schema.json",
  "title": "XGC2 Product Metadata",
  "type": "object",
  "required": ["schema", "id", "name", "kind"],
  "additionalProperties": false,
  "properties": {
    "schema": {
      "const": "xgc2.product.v1"
    },
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9._-]*$"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "kind": {
      "type": "string",
      "enum": [
        "ros1-apt",
        "ros2-apt",
        "toolchain-apt",
        "desktop-apt",
        "webui-docker",
        "app-store",
        "docker-image",
        "mixed"
      ]
    },
    "summary": {
      "type": "string"
    },
    "groups": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9][a-z0-9._-]*$"
      },
      "uniqueItems": true
    },
    "lifecycle": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "deprecated": {
          "type": "boolean"
        },
        "replaced_by": {
          "type": "string"
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "ros": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "distro": {
          "type": "string"
        },
        "workspace": {
          "type": "string"
        },
        "packages": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        }
      }
    },
    "apt": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "distribution": {
          "type": "string"
        },
        "install": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "packages": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "package_architectures": {
          "description": "Optional per-package architecture availability. Packages omitted here default to amd64+arm64; apt.install packages must remain available on both.",
          "type": "object",
          "propertyNames": {
            "type": "string",
            "minLength": 1
          },
          "additionalProperties": {
            "type": "array",
            "items": {
              "enum": [
                "amd64",
                "arm64"
              ]
            },
            "minItems": 1,
            "uniqueItems": true
          }
        },
        "package_distributions": {
          "description": "Optional per-package distribution availability. Packages omitted here default to every apt.distribution value.",
          "type": "object",
          "propertyNames": {
            "type": "string",
            "minLength": 1
          },
          "additionalProperties": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^[a-z0-9][a-z0-9._-]*$"
            },
            "minItems": 1,
            "uniqueItems": true
          }
        },
        "depends": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "recommends": {
          "description": "Debian soft runtime dependencies. Internal packages still require an explicit release.dependency_policy edge, normally verify.",
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        }
      }
    },
    "docker": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "images": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        }
      }
    },
    "app_store": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "app_id": {
          "type": "string"
        }
      }
    },
    "usage": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "install": {
          "type": "string"
        },
        "smoke_test": {
          "type": "string"
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "ownership": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "paths": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        }
      }
    },
    "conflicts": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "ros_packages": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "apt_packages": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        }
      }
    },
    "release": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "repository": {
          "type": "string",
          "minLength": 1
        },
        "ref": {
          "type": "string",
          "minLength": 1
        },
        "workflow": {
          "type": "string",
          "minLength": 1
        },
        "ci_workflow": {
          "description": "Push CI workflow that produces trusted xgc2.build-artifact.v1 artifacts.",
          "type": "string",
          "minLength": 1
        },
        "requires": {
          "description": "Product ids that must be published and APT-visible before this release runs.",
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9._-]*$"
          },
          "uniqueItems": true
        },
        "dependency_policy": {
          "description": "Required explicit release-impact classification for every direct internal apt.depends, apt.recommends, or release.requires upstream edge. Keys are upstream product ids, not Debian package names: rebuild, compatibility verify, or ordering only.",
          "type": "object",
          "propertyNames": {
            "pattern": "^[a-z0-9][a-z0-9._-]*$"
          },
          "additionalProperties": {
            "enum": ["rebuild", "verify", "order"]
          }
        },
        "apt_versions": {
          "type": "object",
          "additionalProperties": {
            "type": "string",
            "minLength": 1
          }
        },
        "apt_version_template": {
          "type": "string",
          "minLength": 1
        },
        "skip_apt_verify": {
          "type": "boolean"
        },
        "inputs": {
          "type": "object",
          "additionalProperties": {
            "type": [
              "string",
              "number",
              "boolean"
            ]
          }
        }
      }
    }
  }
}
