      "id": "xgc2-acados",
      "kind": "toolchain-apt",
      "name": "XGC2 acados",
      "ownership": {
        "paths": [
          "/opt/xgc2/acados",
          "/usr/lib/cmake/xgc2_acados",
          "/etc/ld.so.conf.d/xgc2-acados.conf"
        ]
      },
      "schema": "xgc2.product.v1",
      "summary": "System-level acados solver stack for XGC2 projects on Ubuntu 20.04, 22.04, and 24.04.",
      "usage": {
        "install": "sudo apt update\nsudo apt install xgc2-acados\n",
        "notes": "CMake consumers should use find_package(xgc2_acados REQUIRED CONFIG).\nMATLAB users should run /opt/xgc2/acados/setup_acados.m.\n",
        "smoke_test": "source /opt/xgc2/acados/setup.bash\npython3 -c 'from acados_template import AcadosOcp'\n"
      }
    },
